#!/usr/bin/env bash
# commit-msg — Validador de Conventional Commits para Makan72
# Instalado em: .git/hooks/commit-msg via setup-hooks.sh

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Ignorar merge commits e reverts automáticos
if echo "$COMMIT_MSG" | grep -qE "^Merge |^Revert "; then
    exit 0
fi

# Ignorar auto-commits do end-session
if echo "$COMMIT_MSG" | grep -qE "^chore\(session\): auto-save"; then
    exit 0
fi

# Padrão Conventional Commits
PATTERN='^(feat|fix|refactor|docs|style|test|chore|perf|revert|ci)(\([a-z0-9_/+-]+\))?(!)?: .{1,72}'

if ! echo "$COMMIT_MSG" | head -n1 | grep -qE "$PATTERN"; then
    echo ""
    echo "  ❌ Formato de commit inválido!"
    echo ""
    echo "  Esperado:  tipo(scope): descrição curta"
    echo "  Exemplo:   feat(05-scripts): adicionar commit.sh interactivo"
    echo ""
    echo "  Tipos válidos:"
    echo "    feat | fix | refactor | docs | style | test | chore | perf | revert"
    echo ""
    echo "  Scopes Makan72:"
    echo "    00-global | 01-config | 02-bots | 03-inbox | 04-bus"
    echo "    05-scripts | 06-reports | 07-archive | 08-logs | 09-workspace"
    echo "    system | agent | session | setup"
    echo ""
    echo "  Teu commit: $(echo "$COMMIT_MSG" | head -n1)"
    echo ""
    exit 1
fi

exit 0
