cmd_launch() {
    # === ZELLIJ INTEGRATION — Director + Cameras ===
    local layout_file="$MAKAN72_HOME/01-config/layouts/makan72.kdl"
    local config_file="$MAKAN72_HOME/01-config/zellij-makan72.kdl"

    # Verificar Zellij disponível
    if ! command -v zellij &>/dev/null; then
        echo -e "${YELLOW}AVISO:${NC} Zellij não encontrado. Instala: https://zellij.dev" >&2
        return 1
    fi

    # Não permitir lançar dentro de outra sessão Zellij
    if [[ -n "${ZELLIJ:-}" ]]; then
        echo -e "${YELLOW}AVISO:${NC} Já estás numa sessão Zellij. Sai primeiro (Ctrl+Q)." >&2
        return 1
    fi

    # Limpar sessões Zellij mortas para evitar acumulação
    zellij delete-all-sessions -y 2>/dev/null || true

    # Se sessão Makan72 já existe, matar e recriar (layout fresco)
    if zellij list-sessions -n 2>/dev/null | grep -q "^Makan72 "; then
        zellij kill-session Makan72 2>/dev/null || true
        sleep 0.3
        zellij delete-all-sessions -y 2>/dev/null || true
    fi

    # Gerar layout fresco
    cmd_generate_layout

    # Verificar que o layout existe
    if [[ ! -f "$layout_file" ]]; then
        error "Layout não gerado. Verifica agents.json."
        return 1
    fi

    # Lançar Zellij com sessão nomeada "Makan72"
    # NOTA: --layout + --session = attach (falha se não existe)
    #       --new-session-with-layout (-n) = sempre cria sessão nova
    if [[ ! -f "$config_file" ]]; then
        echo -e "${YELLOW}AVISO:${NC} Config zellij-makan72.kdl não encontrado — usando defaults" >&2
        exec zellij -s Makan72 -n "$layout_file"
    else
        info "A iniciar workspace Makan72..."
        exec zellij -s Makan72 --config "$config_file" -n "$layout_file"
    fi
}

