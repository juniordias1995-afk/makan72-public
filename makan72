# === INFO ===
cmd_info() {
    echo "Makan72 v$VERSION"
    echo "=========================================="
    
    # Home
    echo "  Home:     $MAKAN72_HOME"
    
    # Agentes (jq — seguro com paths que têm espaços/aspas)
    if [[ -f "$AGENTS_FILE" ]]; then
        local active_count=$(jq '[.agents[] | select(.status=="active")] | length' "$AGENTS_FILE" 2>/dev/null || echo 0)
        local paused_count=$(jq '[.agents[] | select(.status=="paused")] | length' "$AGENTS_FILE" 2>/dev/null || echo 0)
        echo "  Agentes:  $active_count activos, $paused_count pausados"
    else
        echo "  Agentes:  N/A"
    fi

    # Projecto (jq — sem Python inline)
    if [[ -f "$PROJECTS_FILE" ]]; then
        local active_project=$(jq -r '.active_project // empty' "$PROJECTS_FILE" 2>/dev/null)
        if [[ -n "$active_project" ]]; then
            local proj_name=$(jq -r --arg id "$active_project" '.projects[] | select(.id==$id) | .name // "N/A"' "$PROJECTS_FILE" 2>/dev/null)
            local proj_path=$(jq -r --arg id "$active_project" '.projects[] | select(.id==$id) | .path // "N/A"' "$PROJECTS_FILE" 2>/dev/null)
            echo "  Projecto: $proj_name ($proj_path)"
        else
            echo "  Projecto: Nenhum activo"
        fi
    fi

    # Sessao (grep — sem dependência de Python yaml)
    if [[ -f "$SESSAO_FILE" ]]; then
        local sessao_activa=$(grep -E "^\s+activa:" "$SESSAO_FILE" 2>/dev/null | awk '{print $2}' | head -1)
        if [[ "$sessao_activa" == "true" ]]; then
            echo "  Sessao:   EM_CURSO"
        else
            echo "  Sessao:   INACTIVA"
        fi
    else
        echo "  Sessao:   N/A"
    fi
    
    # Saude
    echo "  Saude:    OK (use 'makan72 health' para verificar)"
}

# === LAYOUT ===
cmd_layout() {
    cmd_generate_layout "$@"
}

# === GENERATE LAYOUT (interno) ===
cmd_generate_layout() {
    local layouts_dir="$MAKAN72_HOME/01-config/layouts"
    mkdir -p "$layouts_dir"

    local output_file="$layouts_dir/makan72.kdl"

    # Ler dados dos agentes activos
    local active_agents=$(python3 << PYEOF
import json
with open('$AGENTS_FILE') as f:
    data = json.load(f)
agents = [a for a in data.get('agents', []) if a.get('status') == 'active']
for a in agents:
    print(f"{a['code']}|{a['cli']}|{a['name']}")
PYEOF
)

    # Ler projecto activo
    local project_name=""
    local project_path="$MAKAN72_HOME"
    local template_name=""
    if [[ -f "$PROJECTS_FILE" ]]; then
        IFS='|' read -r project_name project_path template_name <<< $(python3 -c "
import json
try:
    with open('$PROJECTS_FILE') as f:
        data = json.load(f)
    active_id = data.get('active_project')
    if active_id:
        for p in data.get('projects', []):
            if p.get('id') == active_id:
                # Tentar detectar template pelo nome ou path
                template = 'base'
                print(f\"{p.get('name', 'N/A')}|{p.get('path', '$MAKAN72_HOME')}|{template}\")
                break
    else:
        print('N/A|$MAKAN72_HOME|base')
except: pass" 2>/dev/null)
    fi

    # Resolver path relativo → absoluto (evita cwd relativo no KDL)
    if [[ -n "$project_path" && "$project_path" != /* ]]; then
        project_path="$(realpath "$project_path" 2>/dev/null || echo "$HOME/$project_path")"
    fi

    # Gerar KDL — Layout MELHORADO vs .team
    cat > "$output_file" << KDLEOF
layout {
    // CWD global dinâmico (projecto activo)
    cwd "$project_path"

    // Tab bar compacta — sem branding "Zellij"
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:compact-bar"
        }
        children
        pane size=1 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

KDLEOF


    # === GERAR 5 SLOTS FIXOS (baseado no campo "tab" de agents.json) ===
    local TOTAL_SLOTS=5

    # Criar mapa slot→agente baseado no campo "tab"
    declare -A slot_map  # slot_map[1]="CODE|cli|name"
    while IFS='|' read -r code cli name tab_num; do
        [[ -z "$code" ]] && continue
        [[ "$tab_num" -ge 1 && "$tab_num" -le $TOTAL_SLOTS ]] 2>/dev/null && \
            slot_map[$tab_num]="$code|$cli|$name"
    done < <(python3 << PYEOF2
import json
with open('$AGENTS_FILE') as f:
    data = json.load(f)
agents = [a for a in data.get('agents', []) if a.get('status') == 'active']
for a in agents:
    tab = a.get('tab', 0)
    if tab >= 1 and tab <= $TOTAL_SLOTS:
        print(f"{a['code']}|{a['cli']}|{a['name']}|{tab}")
PYEOF2
)

    local slot_num
    for slot_num in $(seq 1 $TOTAL_SLOTS); do
        local agent_entry="${slot_map[$slot_num]:-}"
        local focus_attr=""
        [[ $slot_num -eq 1 ]] && focus_attr="focus=true"

        if [[ -n "$agent_entry" ]]; then
            # SLOT COM AGENTE — auto-start via makan72 agent start
            IFS='|' read -r _code _cli _name <<< "$agent_entry"
            cat >> "$output_file" << SLOTEOF
    tab name="Slot-$slot_num" $focus_attr {
        pane split_direction="vertical" {
            pane size="50%" {
                command "bash"
                args "-c" "export MAKAN72_HOME=\\"$MAKAN72_HOME\\"; makan72 agent start $_code"
                name "Slot-$slot_num-$_code"
            }
            pane size="50%" {
                command "bash"
                args "-c" "echo ''; echo '  ╔════════════════════════════════════════╗'; echo '  ║   SLOT $slot_num · $_code · Terminal        ║'; echo '  ╚════════════════════════════════════════╝'; echo ''; echo '  Terminal livre para:'; echo '    - lazygit / git'; echo '    - testes / comandos'; echo ''; exec bash"
                name "Slot-$slot_num-Terminal"
            }
        }
    }

SLOTEOF
        else
            # SLOT LIVRE — instruções para iniciar manualmente
            cat >> "$output_file" << SLOTEOF
    tab name="Slot-$slot_num" $focus_attr {
        pane split_direction="vertical" {
            pane size="50%" {
                command "bash"
                args "-c" "echo ''; echo '  ╔════════════════════════════════════════╗'; echo '  ║   SLOT $slot_num · [LIVRE]                  ║'; echo '  ╚════════════════════════════════════════╝'; echo ''; echo '  Iniciar agente aqui:'; echo '    makan72 agent start <CODE>'; echo ''; echo '  Agentes disponíveis:'; echo '    makan72 agent list'; echo ''; exec bash"
                name "Slot-$slot_num-A"
            }
            pane size="50%" {
                command "bash"
                args "-c" "echo ''; echo '  ╔════════════════════════════════════════╗'; echo '  ║   SLOT $slot_num · Terminal                 ║'; echo '  ╚════════════════════════════════════════╝'; echo ''; exec bash"
                name "Slot-$slot_num-B"
            }
        }
    }

SLOTEOF
        fi
    done

    # Sumário para o CEO
    for slot_num in $(seq 1 $TOTAL_SLOTS); do
        local agent_entry="${slot_map[$slot_num]:-}"
        if [[ -n "$agent_entry" ]]; then
            IFS='|' read -r _code _cli _name <<< "$agent_entry"
            echo "  $slot_num. $_code ($_name) — AUTO-START"
        else
            echo "  $slot_num. [LIVRE] — makan72 slot set $slot_num <CODE>"
        fi
    done

    # Listar MAP com SYS bar
    echo "  6. MAP | Estrutura 37% + Flow 58% + SYS bar 5%"
    # Gerar tab MAP (Estrutura 37% + FLOW.txt 58% + SYS bar 5%)
    cat >> "$output_file" << MAPEOF
    // ═══════════════════════════════════════════════════════════
    // Tab MAP — Estrutura + Diagrama + SYS bar (MELHORIA vs .team)
    // ═══════════════════════════════════════════════════════════
    tab name="MAP" {
        pane split_direction="horizontal" {
            // Conteúdo principal
            pane split_direction="vertical" {
                // Estrutura de ficheiros (40%)
                pane size="40%" {
                    command "bash"
                    args "-c" "cd '$project_path' && echo '=== PROJECTO: $project_name ===' && echo '  Path: $project_path' && echo '' && (tree -L 2 --dirsfirst -C -I '__pycache__|node_modules|.git|build|.dart_tool' 2>/dev/null || find . -maxdepth 2 -type f | grep -v '.git/' | head -50) && echo '' && echo '--- Info ---' && echo \"  Ficheiros: \$(find . -type f | grep -v '.git/' | wc -l)\" && echo \"  Git: \$(git branch --show-current 2>/dev/null || echo 'N/A')\" && exec bash"
                    name "Estrutura"
                }
                // Diagrama de fluxo (60%)
                pane size="60%" {
                    command "bash"
                    args "-c" "if [ -f '$project_path/docs/FLOW.txt' ]; then cat '$project_path/docs/FLOW.txt'; else echo ''; echo '  Sem diagrama de fluxo.'; echo ''; echo '  Cria docs/FLOW.txt no projecto'; echo '  para ver o diagrama aqui.'; echo ''; echo '  Dica: makan72 project info'; fi && exec bash"
                    name "Flow"
                }
            }
            // SYS bar no fundo — 1 linha fixa CPU/GPU/RAM
            pane size=1 {
                command "bash"
                args "-c" "while true; do printf '\r  CPU: %s%%  │  GPU: %s  │  RAM: %s  ' \"\$(top -bn1 | grep 'Cpu(s)' | awk '{printf \"%.0f\", \$2}')\" \"\$(nvidia-smi --query-gpu=utilization.gpu,memory.used --format=csv,noheader,nounits 2>/dev/null | awk -F', ' '{printf \"%s%% %sMB\", \$1, \$2}' || echo 'N/A')\" \"\$(free -h | awk '/Mem/{printf \"%s/%s\", \$3, \$2}')\"; sleep 5; done"
                name "SYS"
            }
        }
    }
MAPEOF

    echo "}" >> "$output_file"

    # Output — mostrar na ordem correcta
    success "Layout Zellij gerado: $output_file"
    echo ""
    echo "Tabs gerados (MELHORADO vs .team):"
    echo ""
    echo "MELHORIAS vs .team:"
    echo "  ✓ File Watcher substitui Terminal (inútil)"
    echo "  ✓ SYS bar (5%) no MAP — SEM tab Monitor"
    echo "  ✓ start-agent.sh dinâmico (lê agents.json)"
    echo "  ✓ cwd dinâmico no projecto activo"

    echo ""
    echo "Projecto activo: $project_name ($project_path)"
    if [[ -f "$project_path/docs/FLOW.txt" ]]; then
        echo "Diagrama: docs/FLOW.txt (SIM)"
    else
        echo "Diagrama: docs/FLOW.txt (NAO existe)"
    fi
    echo ""
    echo "Para usar:"
    echo "  zellij --layout $output_file"
}

