#!/usr/bin/env bash
# makan72 — CLI Wrapper Unificado
set -euo pipefail

MAKAN72_HOME="${MAKAN72_HOME:-$HOME/.Makan72}"
VERSION=$(cat "$MAKAN72_HOME/VERSION" 2>/dev/null || echo "unknown")
PROJECTS_FILE="$MAKAN72_HOME/01-config/projects.json"
AGENTS_FILE="$MAKAN72_HOME/01-config/agents.json"
SESSAO_FILE="$MAKAN72_HOME/00-global/SESSAO_HOJE.yaml"

# Carregar funcoes partilhadas
FUNCTIONS_FILE="$MAKAN72_HOME/05-scripts/core/makan72-functions.sh"
[ -f "$FUNCTIONS_FILE" ] && source "$FUNCTIONS_FILE"

# Cores
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

error() { echo -e "${RED}ERRO:${NC} $1" >&2; exit 1; }
success() { echo -e "${GREEN}$1${NC}"; }
info() { echo -e "${BLUE}$1${NC}"; }
header() { echo -e "${CYAN}$1${NC}"; }

# === PROJECT MANAGEMENT ===
cmd_project() {
    bash "$MAKAN72_HOME/05-scripts/core/manage-projects.sh" "$@"
}

# === AGENTS ===
cmd_agent() {
    local subcmd="${1:-}"
    case "$subcmd" in
        start)
            shift
            bash "$MAKAN72_HOME/05-scripts/core/start-agent.sh" "$@"
            ;;
        stop|attach|sessions|cleanup)
            shift
            bash "$MAKAN72_HOME/05-scripts/core/manage-agents.sh" "$subcmd" "$@"
            ;;
        *)
            bash "$MAKAN72_HOME/05-scripts/core/manage-agents.sh" "$@"
            ;;
    esac
}

# === SYSTEM ===
cmd_start() {
    # Passo 1: Auto-detectar projecto + pedir missão (interactivo — visível)
    local PROJECT="${PROJECT:-}"
    local MISSION="${MISSION:-}"
    local LEADER="${LEADER:-CEO}"

    # Parse argumentos --project=, --mission=, --leader=
    local args=()
    for arg in "$@"; do
        case "$arg" in
            --project=*) PROJECT="${arg#*=}" ;;
            --mission=*) MISSION="${arg#*=}" ;;
            --leader=*)  LEADER="${arg#*=}" ;;
            *) args+=("$arg") ;;
        esac
    done

    # Auto-detectar projecto activo
    if [[ -z "$PROJECT" ]]; then
        local PROJECTS_FILE="$MAKAN72_HOME/01-config/projects.json"
        if [[ -f "$PROJECTS_FILE" ]]; then
            PROJECT=$(jq -r '.projects[] | select(.active==true) | .name' "$PROJECTS_FILE" 2>/dev/null | head -1)
            [[ "$PROJECT" == "null" ]] && PROJECT=""
        fi
    fi

    # Perguntas interactivas
    if [[ -n "$PROJECT" ]]; then
        echo -e "Projecto: ${CYAN}$PROJECT${NC} (auto)"
    else
        read -p "Projecto: " PROJECT
    fi
    [[ -z "$MISSION" ]] && read -p "Missão: " MISSION

    if [[ -z "$PROJECT" || -z "$MISSION" ]]; then
        echo -e "${RED}ERRO:${NC} Projecto e Missão são obrigatórios" >&2
        return 1
    fi

    # === PASSO SLOTS: Mostrar default e perguntar ===
    # Ler defaults do agents.json (campo "tab")
    local _slot_default=""
    local _slot_display=""
    for _sn in 1 2 3 4 5; do
        local _ag
        _ag=$(jq -r --argjson t "$_sn" \
            '.agents[] | select(.status=="active" and .tab==$t) | .code' \
            "$AGENTS_FILE" 2>/dev/null | head -1)
        if [[ -n "$_ag" && "$_ag" != "null" ]]; then
            _slot_default="${_slot_default}${_sn}:${_ag} "
            _slot_display="${_slot_display} ${_sn}:${GREEN}${_ag}${NC}"
        else
            _slot_display="${_slot_display} ${_sn}:${YELLOW}—${NC}"
        fi
    done
    _slot_default="${_slot_default% }"

    echo -e "Slots [${_slot_display} ]"
    read -p "Enter=aceitar, ou novo (ex: 1:QWEN,2:CLAUDE,3:GEMINI): " SLOT_INPUT

    # Se user digitou algo, aplicar as mudanças ao agents.json
    if [[ -n "$SLOT_INPUT" ]]; then
        # Parse: "1:CLAUDE,2:QWEN,3:GEMINI" ou "4:OPENCODE"
        local _pairs="${SLOT_INPUT//,/ }"
        local _tmp_agents="/tmp/m72_agents_$$.json"

        # Recolher slots e codes em arrays
        local _slots_arr=()
        local _codes_arr=()
        for _pair in $_pairs; do
            local _slot_n="${_pair%%:*}"
            local _slot_code="${_pair##*:}"
            _slot_code="${_slot_code^^}"
            if [[ "$_slot_n" =~ ^[1-5]$ ]]; then
                _slots_arr+=("$_slot_n")
                _codes_arr+=("$_slot_code")
            fi
        done

        # Construir JSON array dos pares para jq processar de uma vez
        local _jq_pairs="["
        for _i in "${!_slots_arr[@]}"; do
            [[ $_i -gt 0 ]] && _jq_pairs+=","
            _jq_pairs+="{\"slot\":${_slots_arr[$_i]},\"code\":\"${_codes_arr[$_i]}\"}"
        done
        _jq_pairs+="]"

        # Aplicar TUDO de uma vez: limpar slots mencionados + codes mencionados, depois atribuir
        jq --argjson pairs "$_jq_pairs" '
            ($pairs | map(.slot)) as $slots_to_clear |
            ($pairs | map(.code)) as $codes_to_clear |
            .agents = [.agents[] |
                # Primeiro: limpar tab de quem vai ser movido ou de quem ocupa os slots
                if (.code as $c | $codes_to_clear | index($c)) != null then .tab = 0
                elif (.tab as $t | $slots_to_clear | index($t)) != null then .tab = 0
                else . end
            ] |
            # Depois: atribuir os novos slots
            reduce $pairs[] as $p (.;
                .agents = [.agents[] | if .code == $p.code then .tab = $p.slot else . end]
            )
        ' "$AGENTS_FILE" > "$_tmp_agents" && cp "$_tmp_agents" "$AGENTS_FILE"
        rm -f "$_tmp_agents"
        echo -e "${GREEN}Slots actualizados.${NC}"
    fi

    # Mostrar configuração final
    echo ""
    for _sn in 1 2 3 4 5; do
        local _ag
        _ag=$(jq -r --argjson t "$_sn" \
            '.agents[] | select(.status=="active" and .tab==$t) | .code' \
            "$AGENTS_FILE" 2>/dev/null | head -1)
        if [[ -n "$_ag" && "$_ag" != "null" ]]; then
            echo -e "  Slot-${_sn}: ${GREEN}${_ag}${NC} (auto-start)"
        fi
    done
    echo ""

    # Passo 2: Setup administrativo (SILENCIOSO — log)
    local LOG_FILE="$MAKAN72_HOME/08-logs/start-session.log"
    mkdir -p "$MAKAN72_HOME/08-logs"
    bash "$MAKAN72_HOME/05-scripts/utils/start-session.sh" \
        --project="$PROJECT" --mission="$MISSION" --leader="$LEADER" \
        > "$LOG_FILE" 2>&1
    local exit_code=$?

    if [[ $exit_code -ne 0 ]]; then
        echo -e "${RED}ERRO:${NC} Falha no setup da sessão. Ver: $LOG_FILE" >&2
        return $exit_code
    fi

    echo -e "${GREEN}✅${NC} Sessão: ${CYAN}$PROJECT${NC} → $MISSION"
    echo ""

    # Passo 3: Lançar workspace visual (Zellij)
    if [[ -n "${ZELLIJ:-}" ]]; then
        echo -e "${YELLOW}AVISO:${NC} Já estás numa sessão Zellij. Usa 'makan72 launch' para nova sessão." >&2
        return 0
    fi

    if command -v zellij &>/dev/null; then
        cmd_launch
    else
        echo -e "${YELLOW}AVISO:${NC} Zellij não disponível. Sessão iniciada sem workspace visual." >&2
    fi
}

cmd_stop() {
    if [[ "${1:-}" == "--all" ]]; then
        # T3: Matar todos os agentes e fechar sessão
        m72_clean_all 2>/dev/null || true
        bash "$MAKAN72_HOME/05-scripts/utils/end-session.sh"
    elif [[ -n "${1:-}" ]]; then
        # Matar agente específico — converter CODE para cli
        local agent_code="$1"
        local agent_cli
        agent_cli=$(jq -r --arg code "$agent_code" 
            '.agents[] | select(.code == $code) | .cli' 
            "$AGENTS_FILE" 2>/dev/null)

        if [[ -z "$agent_cli" || "$agent_cli" == "null" ]]; then
            echo -e "${RED}ERRO: Agente '$agent_code' não encontrado em agents.json${NC}"
            echo "Usa: makan72 agent list para ver agentes disponíveis"
            return 1
        fi

        # Matar sessão do agente
        m72_kill_agent "$agent_cli"
        echo -e "${GREEN}Agente $agent_code ($agent_cli) parado${NC}"
    else
        # Sem argumentos — apenas fechar sessão
        bash "$MAKAN72_HOME/05-scripts/utils/end-session.sh"
    fi
}

cmd_status() {
    bash "$MAKAN72_HOME/05-scripts/utils/show-status.sh" "$@"
}

cmd_peek() {
    local agent_code="${1:-}"

    if [[ -z "$agent_code" ]]; then
        echo -e "${RED}ERRO: Especifica o agente. Ex: makan72 peek CLAUDE${NC}"
        return 1
    fi

    # Converter CODE para cli
    local agent_cli
    agent_cli=$(jq -r --arg code "$agent_code" 
        '.agents[] | select(.code == $code) | .cli' 
        "$AGENTS_FILE" 2>/dev/null)

    if [[ -z "$agent_cli" || "$agent_cli" == "null" ]]; then
        echo -e "${RED}ERRO: Agente '$agent_code' não encontrado em agents.json${NC}"
        return 1
    fi

    # Converter cli para slot number via active_slots.json
    local slots_file="$MAKAN72_HOME/04-bus/active_slots.json"
    if [[ ! -f "$slots_file" ]]; then
        echo -e "${YELLOW}Nenhuma sessão activa${NC}"
        return 0
    fi

    local slot_num
    slot_num=$(jq -r --arg cli "$agent_cli" 
        '.slots[] | select(.cli == $cli) | .slot' 
        "$slots_file" 2>/dev/null)

    if [[ -z "$slot_num" || "$slot_num" == "null" ]]; then
        echo -e "${YELLOW}Agente $agent_code não tem sessão activa${NC}"
        return 0
    fi

    m72_get_output "$slot_num"
}

