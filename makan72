# === SLOT MANAGEMENT ===
cmd_slot() {
    local subcmd="${1:-list}"
    shift 2>/dev/null || true

    case "$subcmd" in
        set)
            # makan72 slot set <N> <CODE>
            local slot_num="${1:-}"
            local code="${2:-}"
            [[ -z "$slot_num" || -z "$code" ]] && { echo "Uso: makan72 slot set <1-5> <CODE>"; return 1; }
            [[ "$slot_num" -ge 1 && "$slot_num" -le 5 ]] 2>/dev/null || { error "Slot deve ser 1-5"; return 1; }
            code=$(echo "$code" | tr '[:lower:]' '[:upper:]')

            # Verificar se agente existe e está activo
            local agent_exists
            agent_exists=$(jq -r ".agents[] | select(.code==\"$code\" and .status==\"active\") | .code" "$AGENTS_FILE" 2>/dev/null)
            [[ -z "$agent_exists" ]] && { error "Agente $code não existe ou não está activo. Usa 'makan72 agent add' primeiro."; return 1; }

            # Verificar se slot já está ocupado por outro agente
            local current_occupant
            current_occupant=$(jq -r ".agents[] | select(.tab==$slot_num and .status==\"active\") | .code" "$AGENTS_FILE" 2>/dev/null)
            if [[ -n "$current_occupant" && "$current_occupant" != "$code" ]]; then
                echo -e "${YELLOW}⚠ Slot $slot_num ocupado por $current_occupant — será libertado${NC}"
                local tmp_file=$(mktemp)
                jq "(.agents[] | select(.code==\"$current_occupant\") | .tab) = 0" "$AGENTS_FILE" > "$tmp_file" && mv "$tmp_file" "$AGENTS_FILE"
            fi

            # Limpar tab anterior do agente (se tinha outro slot)
            local tmp_file=$(mktemp)
            jq "(.agents[] | select(.code==\"$code\") | .tab) = $slot_num" "$AGENTS_FILE" > "$tmp_file" && mv "$tmp_file" "$AGENTS_FILE"

            success "✅ $code → Slot $slot_num"
            ;;

        clear)
            # makan72 slot clear <N>
            local slot_num="${1:-}"
            [[ -z "$slot_num" ]] && { echo "Uso: makan72 slot clear <1-5>"; return 1; }
            [[ "$slot_num" -ge 1 && "$slot_num" -le 5 ]] 2>/dev/null || { error "Slot deve ser 1-5"; return 1; }

            local current_occupant
            current_occupant=$(jq -r ".agents[] | select(.tab==$slot_num and .status==\"active\") | .code" "$AGENTS_FILE" 2>/dev/null)
            if [[ -z "$current_occupant" ]]; then
                echo -e "${YELLOW}Slot $slot_num já está livre${NC}"
                return 0
            fi

            local tmp_file=$(mktemp)
            jq "(.agents[] | select(.tab==$slot_num) | .tab) = 0" "$AGENTS_FILE" > "$tmp_file" && mv "$tmp_file" "$AGENTS_FILE"
            success "✅ Slot $slot_num libertado ($current_occupant → sem slot)"
            ;;

        swap)
            # makan72 slot swap <N> <M>
            local slot_a="${1:-}"
            local slot_b="${2:-}"
            [[ -z "$slot_a" || -z "$slot_b" ]] && { echo "Uso: makan72 slot swap <1-5> <1-5>"; return 1; }

            local agent_a agent_b
            agent_a=$(jq -r ".agents[] | select(.tab==$slot_a and .status==\"active\") | .code" "$AGENTS_FILE" 2>/dev/null)
            agent_b=$(jq -r ".agents[] | select(.tab==$slot_b and .status==\"active\") | .code" "$AGENTS_FILE" 2>/dev/null)

            local tmp_file=$(mktemp)
            # Limpar ambos os slots primeiro
            jq "(.agents[] | select(.tab==$slot_a) | .tab) = 0 | (.agents[] | select(.tab==$slot_b) | .tab) = 0" "$AGENTS_FILE" > "$tmp_file" && mv "$tmp_file" "$AGENTS_FILE"

            # Atribuir novos slots
            if [[ -n "$agent_a" ]]; then
                tmp_file=$(mktemp)
                jq "(.agents[] | select(.code==\"$agent_a\") | .tab) = $slot_b" "$AGENTS_FILE" > "$tmp_file" && mv "$tmp_file" "$AGENTS_FILE"
            fi
            if [[ -n "$agent_b" ]]; then
                tmp_file=$(mktemp)
                jq "(.agents[] | select(.code==\"$agent_b\") | .tab) = $slot_a" "$AGENTS_FILE" > "$tmp_file" && mv "$tmp_file" "$AGENTS_FILE"
            fi

            success "✅ Swap: ${agent_a:-[vazio]} (slot $slot_a) ↔ ${agent_b:-[vazio]} (slot $slot_b)"
            ;;

        list|"")
            echo ""
            echo "╔══════════════════════════════════════╗"
            echo "║         SLOTS MAKAN72 (1-5)         ║"
            echo "╠══════════════════════════════════════╣"
            for s in 1 2 3 4 5; do
                local agent
                agent=$(jq -r ".agents[] | select(.tab==$s and .status==\"active\") | \"\(.code) (\(.cli))\"" "$AGENTS_FILE" 2>/dev/null)
                if [[ -n "$agent" ]]; then
                    printf "║  Slot %d: %-28s ║\n" "$s" "$agent"
                else
                    printf "║  Slot %d: %-28s ║\n" "$s" "[LIVRE]"
                fi
            done
            echo "╠══════════════════════════════════════╣"
            echo "║  Slot 6: MAP (fixo)                 ║"
            echo "╚══════════════════════════════════════╝"
            echo ""
            echo "Comandos:"
            echo "  makan72 slot set <1-5> <CODE>   Atribuir agente a slot"
            echo "  makan72 slot clear <1-5>        Libertar slot"
            echo "  makan72 slot swap <N> <M>       Trocar agentes entre slots"
            ;;

        *)
            echo "Uso: makan72 slot {set|clear|swap|list}"
            ;;
    esac
}

